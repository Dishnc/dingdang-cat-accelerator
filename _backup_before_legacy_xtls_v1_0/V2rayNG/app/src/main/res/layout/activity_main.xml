<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ddcat_shell">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#071125"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="#071125"
                app:titleTextColor="#F3FAFF" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="#00D6FF"
                app:trackColor="#14345F" />

        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:id="@+id/main_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_ddcat_shell">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="26dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="28dp">

                    <ImageView
                        android:id="@+id/iv_brand_logo"
                        android:layout_width="92dp"
                        android:layout_height="92dp"
                        android:contentDescription="叮当猫加速器"
                        android:src="@mipmap/ic_launcher" />

                    <TextView
                        android:id="@+id/tv_shell_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="叮当猫加速器"
                        android:textColor="#F5FBFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_shell_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="安全 · 稳定 · 高效"
                        android:textColor="#76DFFF"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/card_login"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_ddcat_card"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="邮箱登录"
                            android:textColor="#F3FAFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="服务地址"
                            android:textColor="#8FA8BE"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/et_api_base_url"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_ddcat_input"
                            android:hint="https://你的域名"
                            android:imeOptions="actionNext"
                            android:inputType="textUri"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:textColor="#F3FAFF"
                            android:textColorHint="#52708D"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="邮箱账号"
                            android:textColor="#8FA8BE"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/et_login_email"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_ddcat_input"
                            android:hint="user@example.com"
                            android:imeOptions="actionDone"
                            android:inputType="textEmailAddress"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:textColor="#F3FAFF"
                            android:textColorHint="#52708D"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btn_login"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_ddcat_primary_button"
                                android:text="登录 / 查询账号"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <Space
                                android:layout_width="10dp"
                                android:layout_height="1dp" />

                            <Button
                                android:id="@+id/btn_refresh_account"
                                android:layout_width="112dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_ddcat_secondary_button"
                                android:text="刷新"
                                android:textAllCaps="false"
                                android:textColor="#BDEFFF"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_api_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="请输入服务地址和邮箱，点击登录查询账号。"
                            android:textColor="#9CB3C9"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_connection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_ddcat_card"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_shell_status_dot"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_ddcat_status_dot_off" />

                            <TextView
                                android:id="@+id/tv_shell_status"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="当前状态：未加速"
                                android:textColor="#F3FAFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_shell_node"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_ddcat_tag"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="智能线路"
                                android:textColor="#91E8FF"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_shell_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="登录后显示真实账号信息，自动导入线路将在下一阶段接入。"
                            android:textColor="#9CB3C9"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/btn_connect"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="22dp"
                            android:background="@drawable/bg_ddcat_primary_button"
                            android:text="一键加速"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_account"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_ddcat_card"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="账号信息"
                            android:textColor="#F3FAFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="账号"
                                android:textColor="#8FA8BE"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_account_email"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未登录"
                                android:textColor="#F3FAFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="套餐状态"
                                android:textColor="#8FA8BE"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_plan_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="待登录后查看"
                                android:textColor="#F3FAFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="到期时间"
                                android:textColor="#8FA8BE"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_expire_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#F3FAFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="流量使用"
                                android:textColor="#8FA8BE"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_traffic_usage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- / --"
                                android:textColor="#F3FAFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="剩余流量"
                                android:textColor="#8FA8BE"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_traffic_remain"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#F3FAFF"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="线路信息"
                            android:textColor="#8FA8BE"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_line_info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_ddcat_tag"
                            android:paddingStart="12dp"
                            android:paddingTop="9dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="9dp"
                            android:text="登录后显示"
                            android:textColor="#BDEFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_actions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_renew"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_ddcat_secondary_button"
                            android:text="套餐续费"
                            android:textAllCaps="false"
                            android:textColor="#BDEFFF"
                            android:textSize="13sp" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <Button
                            android:id="@+id/btn_order"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_ddcat_secondary_button"
                            android:text="在线下单"
                            android:textAllCaps="false"
                            android:textColor="#BDEFFF"
                            android:textSize="13sp" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <Button
                            android:id="@+id/btn_support"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_ddcat_secondary_button"
                            android:text="联系客服"
                            android:textAllCaps="false"
                            android:textColor="#BDEFFF"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_shell_footer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:text="V1.3-B 邮箱登录 · 已接入真实 x-ui APP API"
                        android:textColor="#5F7E9B"
                        android:textSize="12sp" />
                </LinearLayout>
            </ScrollView>

            <!-- Legacy core views kept for binding and bottom-layer compatibility. They are hidden in V1.2 shell mode. -->
            <LinearLayout
                android:id="@+id/legacy_core_container"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:tabIndicatorFullWidth="false"
                    app:tabMode="scrollable"
                    app:tabTextAppearance="@style/TabLayoutTextStyle" />

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/view_pager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:nextFocusRight="@+id/fab"
                    android:scrollbars="vertical" />

                <LinearLayout
                    android:id="@+id/layout_test"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/view_height_dp64"
                    android:clickable="true"
                    android:contentDescription="@string/connection_test_pending"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_test_state"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="start|center"
                        android:maxLines="2"
                        android:minLines="1"
                        android:paddingStart="@dimen/padding_spacing_dp16"
                        android:text="@string/connection_test_pending"
                        android:textAppearance="@style/TextAppearance.AppCompat.Small" />
                </LinearLayout>

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:contentDescription="@string/tasker_start_service"
                    android:focusable="true"
                    android:src="@drawable/ic_play_24dp"
                    app:tint="@color/colorWhite"
                    app:useCompatPadding="true" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:visibility="gone"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
